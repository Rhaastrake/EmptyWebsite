{
  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1"
  },
  "devDependencies": {
    "sass": "^1.97.2",
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "build:css": "sass src/scss:src/css --no-source-map",
    "build:11ty": "eleventy",
    "build": "npm run build:css && npm run build:11ty",

    "serve:css": "sass --watch src/scss:src/css --no-source-map",
    "serve:11ty": "eleventy --serve --quiet",

    "serve": "concurrently \"npm run serve:11ty\" \"npm run serve:css\""
  }
}